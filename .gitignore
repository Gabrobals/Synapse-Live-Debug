# ═══════════════════════════════════════════════════════════════════════════
# Synapse Live Debug - .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/

# ─── Node.js ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ─── IDE / Editors ──────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.codemind/
.cursor/

# ─── OS Files ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Project Specific ───────────────────────────────────────────────────────
# Temporary data dumps
graph_data.json
graph_dump.json
*.bak

# Generated reports
.governor-report.md

# VS Code Extension build output
vscode-extension/out/
vscode-extension/*.vsix

# Environment files (may contain secrets)
.env
.env.local
.env.*.local

# Logs
*.log
logs/
